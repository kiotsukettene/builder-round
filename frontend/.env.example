# API base URL (leave empty in dev to use Vite proxy to localhost:3000)
VITE_API_URL=

# Pusher Beams instance ID (same as backend PUSHER_BEAMS_INSTANCE_ID; safe to expose)
# Create a Beams instance at https://dashboard.pusher.com/ and add your app origin to Allowed origins.
VITE_PUSHER_BEAMS_INSTANCE_ID=your-beams-instance-id
